{
  "feeds": [
    {
      "name": "Warzone Seed",
      "enabled": false,
      "type": "manual-json",
      "parser": "events-array",
      "url": "${SEED_FEED_URL}",
      "category": "strike"
    },
    {
      "name": "ACLED Conflict Feed",
      "enabled": false,
      "type": "acled-api",
      "parser": "acled",
      "url": "https://acleddata.com/api/acled/read",
      "category": "conflict"
    },
    {
      "name": "NASA EONET Wildfires",
      "enabled": false,
      "type": "eonet-api",
      "parser": "eonet",
      "url": "https://eonet.gsfc.nasa.gov/api/v3/events",
      "category": "fire"
    },
    {
      "name": "GDELT Conflict Signals",
      "enabled": false,
      "type": "gdelt-api",
      "parser": "gdelt",
      "url": "https://api.gdeltproject.org/api/v2/doc/doc",
      "category": "signal"
    },
    {
      "name": "Telegram OSINT",
      "enabled": true,
      "type": "telegram",
      "parser": "telegram",
      "category": "military",
      "channels": [
        "strikemap",
        "OSINTLive",
        "wor_mil_news",
        "ClashReport",
        "mmirlb",
        "war_translated",
        "U_S_CENTCOM",
        "ourwarstoday",
        "irannotam"
      ],
      "limit": 25,
      "tags": [ "telegram", "osint", "military" ]
    },
    {
      "name": "Airspace Status Feed",
      "enabled": true,
      "type": "airspace",
      "parser": "airspace",
      "url": "YOUR_AIRSPACE_SOURCE_URL",
      "category": "airspace"
    },
    {
      "name": "Cyber Status Feed",
      "enabled": true,
      "type": "cyber",
      "parser": "cyber",
      "url": "YOUR_CYBER_SOURCE_URL",
      "category": "cyber"
    },
    {
      "name": "Curated Warzone Feed",
      "enabled": true,
      "type": "manual-json",
      "parser": "events-array",
      "url": "https://warzone.battlespacex.com/assets/others/warzone-live-events.json",
      "category": "strike"
    }
  ]
}