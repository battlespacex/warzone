{
  "feeds": [
    {
      "name": "Warzone Seed",
      "enabled": false,
      "type": "manual-json",
      "parser": "events-array",
      "url": "${SEED_FEED_URL}",
      "category": "strike"
    },
    {
      "name": "ACLED Conflict Feed",
      "enabled": false,
      "type": "acled-api",
      "parser": "acled",
      "url": "https://acleddata.com/api/acled/read",
      "category": "conflict"
    },
    {
      "name": "NASA EONET Wildfires",
      "enabled": false,
      "type": "eonet-api",
      "parser": "eonet",
      "url": "https://eonet.gsfc.nasa.gov/api/v3/events",
      "category": "fire"
    },
    {
      "name": "GDELT Conflict Signals",
      "enabled": false,
      "type": "gdelt-api",
      "parser": "gdelt",
      "url": "https://api.gdeltproject.org/api/v2/doc/doc",
      "category": "signal"
    },
    {
      "name": "Telegram OSINT",
      "enabled": true,
      "type": "telegram",
      "parser": "telegram",
      "category": "military",
      "channels": [
        "strikemap",
        "OSINTLive",
        "wor_mil_news",
        "ClashReport",
        "mmirlb",
        "war_translated",
        "frontier_conflict",
        "U_S_CENTCOM",
        "ourwarstoday"
      ],
      "limit": 25,
      "tags": [ "telegram", "osint", "military" ]
    }
  ]
}